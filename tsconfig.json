{
  "compilerOptions": {
    "module": "ES2022",
    "allowJs": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "importHelpers": false,
    "noEmit": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "sourceMap": true,
    "ignoreDeprecations": "6.0",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "strictNullChecks": false,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noEmitOnError": false,
    "noImplicitAny": false
  },
  "include": [
    "src/**/*",
    "src/typings.d.ts"
  ],
  "types": ["estree"]
}
