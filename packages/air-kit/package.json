{
  "name": "air-kit",
  "version": "2.0.0",
  "description": "AirKit - 企业应用前端业务套件（登录、布局、用户管理、跨应用切换等，与 air-design 并列）",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/src/index.d.ts"
    },
    "./config": {
      "import": "./dist/config.mjs",
      "types": "./dist/src/config.d.ts"
    },
    "./models/user": {
      "import": "./dist/models/user.mjs",
      "types": "./dist/src/models/user.d.ts"
    },
    "./layouts/SecurityLayout": {
      "import": "./dist/layouts/SecurityLayout.mjs",
      "types": "./dist/src/layouts/SecurityLayout.d.ts"
    },
    "./pages/Login": {
      "import": "./dist/pages/Login/index.mjs",
      "types": "./dist/src/pages/Login/index.d.ts"
    },
    "./utils/HttpRequest": {
      "import": "./dist/utils/HttpRequest.mjs",
      "types": "./dist/src/utils/HttpRequest.d.ts"
    },
    "./utils/CryptoUtils": {
      "import": "./dist/utils/CryptoUtils.mjs",
      "types": "./dist/src/utils/CryptoUtils.d.ts"
    },
    "./style.css": "./dist/air-kit.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "air-design": ">=2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/react": "^18.3.28",
    "@vitejs/plugin-react": "^6.0.2",
    "air-design": "2.0.0",
    "react": "^18.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-dts": "^5.0.0"
  }
}
