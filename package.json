{
  "name": "air-design",
  "version": "1.0.0",
  "description": "AirMachine 常用 React 组件库，毛玻璃风格 UI 组件",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/norlandsoft/AirDesign.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": [
    "*.css",
    "*.less"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dist/*.css": "./dist/*.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "react",
    "components",
    "ui",
    "glassmorphism",
    "antd"
  ],
  "author": "ChaiMingxu",
  "license": "MIT",
  "scripts": {
    "build": "node scripts/generate-icons.js && rollup -c && node scripts/copy-fonts.js",
    "dev": "rollup -c -w",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,less}\""
  },
  "peerDependencies": {
    "@douyinfe/semi-ui": ">=2.0.0",
    "antd": ">=5.0.0",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.1.0",
    "@fontsource/space-grotesk": "^5.1.0"
  },
  "devDependencies": {
    "@ant-design/colors": "^5.0.0",
    "@ant-design/icons": "^5.5.1",
    "@douyinfe/semi-ui": "^2.89.0",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "antd": "^5.29.1",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "less": "^4.2.0",
    "less-loader": "^12.3.1",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-lifecycles-compat": "^3.0.4",
    "rollup": "^4.28.1",
    "rollup-plugin-less": "^1.1.3",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "style-loader": "^4.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
