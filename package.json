{
  "name": "air-design",
  "version": "1.0.0",
  "description": "AirMachine 常用 React 组件库，毛玻璃风格 UI 组件",
  "private": true,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/*.css": "./dist/*.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node scripts/generate-icons.js && rollup -c && node scripts/copy-fonts.js",
    "dev": "rollup -c -w"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "antd": ">=5.0.0",
    "@douyinfe/semi-ui": ">=2.0.0"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.1.0",
    "@fontsource/space-grotesk": "^5.1.0"
  },
  "devDependencies": {
    "antd": "^5.29.1",
    "@ant-design/colors": "^5.0.0",
    "@ant-design/icons": "^5.5.1",
    "@douyinfe/semi-ui": "^2.89.0",
    "react-lifecycles-compat": "^3.0.4",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "less": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rollup": "^4.28.1",
    "rollup-plugin-less": "^1.1.3",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
