{
  "name": "air-design",
  "version": "1.0.0",
  "description": "AirMachine 常用 React 组件库，毛玻璃风格 UI 组件",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/norlandsoft/AirDesign.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": [
    "*.css",
    "*.less"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dist/*.css": "./dist/*.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "react",
    "components",
    "ui",
    "glassmorphism",
    "antd"
  ],
  "author": "ChaiMingxu",
  "license": "MIT",
  "scripts": {
    "build": "node scripts/generate-icons.js && rollup -c && node scripts/copy-fonts.js",
    "dev": "rollup -c -w",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,less}\""
  },
  "peerDependencies": {
    "antd": ">=6.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10"
  },
  "devDependencies": {
    "@ant-design/colors": "^8.0.1",
    "@ant-design/icons": "^6.2.2",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "antd": "^6.3.7",
    "css-loader": "^7.1.4",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "less": "^4.6.4",
    "less-loader": "^12.3.2",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-lifecycles-compat": "^3.0.4",
    "rollup": "^4.60.3",
    "rollup-plugin-less": "^1.1.3",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "style-loader": "^4.0.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  }
}
