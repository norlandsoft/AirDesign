{
  "name": "air-design",
  "version": "1.0.0",
  "description": "AirMachine React 组件库 + UmiJS Max 场景展示应用",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/norlandsoft/AirDesign.git"
  },
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "sideEffects": [
    "*.css",
    "*.less"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.js"
    },
    "./lib/*.css": "./lib/*.css"
  },
  "files": [
    "lib",
    "src/components/AirDesign"
  ],
  "keywords": [
    "react",
    "components",
    "ui",
    "glassmorphism",
    "antd",
    "umi"
  ],
  "author": "ChaiMingxu",
  "license": "MIT",
  "scripts": {
    "dev": "max dev",
    "build": "max build",
    "build:lib": "node scripts/generate-icons.js && rollup -c && node scripts/copy-fonts.js",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,less}\"",
    "preview": "max preview"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@umijs/max": "^4.4.7",
    "antd": "^6.3.7"
  },
  "devDependencies": {
    "@ant-design/colors": "^8.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.7.0",
    "eslint-plugin-react": "^7.37.5",
    "less": "^4.6.4",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rollup": "^4.60.3",
    "rollup-plugin-less": "^1.1.3",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  }
}
